# Build directories
build/
build-*/
build_*/
cmake-build-*/

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# Compiled objects and libraries
*.o
*.a
*.so
*.dylib
*.dll

# Test / benchmark artifacts
*.jtext
*.bin
jtext_throughput_test.jtext
Binary_*
JText_*
Event_*

# Test runner output (large persist logs, per-run artifacts, sizes, etc.)
# Results are per-disk under test-results/x7k/ , test-results/10k/ , test-results/ssd/
# (all 3-char names for alignment). These dirs are fully ignored.
test-results/

# Lightweight per-disk summaries (the three TS_STORE_*_Summary.md files) are
# copied here by scripts/promote_summaries.sh (called at end of every run).
# These live in a sibling tree so they can be git-tracked and committed as proof
# while the huge test-results/ contents stay out of the repo.
# test-summary/x7k/ , test-summary/10k/ , test-summary/ssd/
!test-summary/

# Temporary files created during development / monitoring
test-log.txt
tail_test_progress.sh

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Rationale (internal decision docs)
Rationale/

# OS
.DS_Store
Thumbs.db