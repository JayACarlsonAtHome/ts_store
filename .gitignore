# Build directories
build/
build-*/
build_*/
cmake-build-*/

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# Compiled objects and libraries
*.o
*.a
*.so
*.dylib
*.dll

# C++23 module BMIs and scanner metadata (never commit — rebuild after clone)
*.gcm
*.pcm
*.ifc
*.ddi
*.modmap
**/CXX.dd

# Test / benchmark artifacts (runtime logs under test-results/)
*.jtext
# C++23 module shim (directory name matches *.jtext)
!modules/jac.jtext/
!modules/jac.jtext/**
# Promoted manifests in test-summary/ are committed proof (override *.jtext above)
!test-summary/**/run_manifest.jtext
*.bin
jtext_throughput_test.jtext
Binary_*
JText_*
Event_*

# Test runner output (large persist logs, per-run artifacts, sizes, etc.)
# Results are per-disk under test-results/x7k/ , test-results/10k/ , test-results/ssd/
# (all 3-char names for alignment). These dirs are fully ignored.
test-results/

# Promoted lightweight summaries: test-summary/README.md hub, per-leaf README.md,
# by_test/*.md, run_manifest.jtext (see exception above). Copied by promote_summaries.sh.
# Layout: test-summary/OS_00n/<compiler>/<disk>/<Smoke|xFull>/...
!test-summary/

# SQLite slurp DBs are regeneratable from manifest (ignore everywhere)
run_manifest.db
**/run_manifest.db

# Temporary files created during development / monitoring
test-log.txt

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Rationale (internal decision docs)
Rationale/

# OS
.DS_Store
Thumbs.db