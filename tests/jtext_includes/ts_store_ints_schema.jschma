//Purpose: SQL Schema File for ts_store integer metrics table (common, 9 ints)
//Related: type=ts_store

CREATE TABLE IF NOT EXISTS ts_store_ints (
    id BIGINT PRIMARY KEY,
    int0 BIGINT,
    int1 BIGINT,
    int2 BIGINT,
    int3 BIGINT,
    int4 BIGINT,
    int5 BIGINT,
    int6 BIGINT,
    int7 BIGINT,
    int8 BIGINT
);
