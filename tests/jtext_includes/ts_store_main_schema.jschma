//Purpose: SQL Schema File for ts_store main event table (common)
//Related: type=ts_store

CREATE TABLE IF NOT EXISTS ts_store_events (
    id BIGINT PRIMARY KEY,
    thread_id BIGINT,
    per_thread_event_id BIGINT,
    flags_raw BIGINT,
    category TEXT,
    payload TEXT,
    timestamp_us BIGINT
);
