#!/bin/bash
# scripts/Build — sequential checklist-driven builder for ts_store
#
# Usage:
#   ./scripts/Build FileCheckList.txt [--FullRebuild=On/Off] [--SmokeTest=On/Off] [--FullTest=On/Off]
#
# Walks FileCheckList.txt top to bottom. Rows marked [x] are built and tested; rows
# marked [ ] are skipped. Continues until end of file.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

CHECKLIST="${1:-FileCheckList.txt}"
shift || true
if [[ "$CHECKLIST" != /* ]]; then
  CHECKLIST="$PROJECT_ROOT/$CHECKLIST"
fi

FULL_REBUILD="Off"
SMOKE_TEST="Off"
FULL_TEST="Off"

for arg in "$@"; do
  case "$arg" in
    --FullRebuild=On)  FULL_REBUILD="On" ;;
    --FullRebuild=Off) FULL_REBUILD="Off" ;;
    --SmokeTest=On)    SMOKE_TEST="On" ;;
    --SmokeTest=Off)   SMOKE_TEST="Off" ;;
    --FullTest=On)     FULL_TEST="On" ;;
    --FullTest=Off)    FULL_TEST="Off" ;;
    *) echo "Unknown arg: $arg" >&2; exit 1 ;;
  esac
done

if [[ ! -f "$CHECKLIST" ]]; then
  echo "Checklist not found: $CHECKLIST" >&2
  exit 1
fi

RUN_COUNT=$(grep -c '^\[x\]' "$CHECKLIST" || true)
if [[ "$RUN_COUNT" -eq 0 ]]; then
  echo "No [x] rows in $CHECKLIST — nothing to run."
  exit 0
fi

normalize_disk() {
  local d="${1,,}"
  d="${d// /}"; d="${d//-/}"; d="${d//_/}"
  case "$d" in
    7k|7200|x7k|seven|seventyk) echo "x7k" ;;
    10k|10|x10k|tenk|ten)       echo "10k" ;;
    ssd|solid|flash)             echo "ssd" ;;
    *) echo "$d" ;;
  esac
}

slugify() {
  echo "$1" | sed 's/[^A-Za-z0-9._-]/_/g' | sed 's/__*/_/g' | sed 's/^_\|_$//g'
}

resolve_compiler() {
  local compiler_field="$1"
  local platform_field="$2"

  CMAKE_WRAPPER=()
  CXX_COMPILER=""
  C_COMPILER=""
  TEST_CLI_COMPILER=""

  if [[ "$compiler_field" == "GCC" ]]; then
    TEST_CLI_COMPILER="gcc"
    if [[ "$platform_field" == *"Mint"* ]]; then
      CXX_COMPILER="g++-15"
      C_COMPILER="gcc-15"
    elif [[ "$platform_field" == RHEL* ]]; then
      if command -v scl >/dev/null 2>&1 && [[ -x /opt/rh/gcc-toolset-15/root/usr/bin/g++ ]]; then
        CMAKE_WRAPPER=(scl enable gcc-toolset-15 --)
        CXX_COMPILER="/opt/rh/gcc-toolset-15/root/usr/bin/g++"
        C_COMPILER="/opt/rh/gcc-toolset-15/root/usr/bin/gcc"
      elif command -v g++-15 >/dev/null 2>&1; then
        CXX_COMPILER="g++-15"
        C_COMPILER="gcc-15"
      else
        echo "ERROR: RHEL GCC row requires gcc-toolset-15 (scl) or g++-15 on PATH." >&2
        return 1
      fi
    elif command -v g++-15 >/dev/null 2>&1; then
      CXX_COMPILER="g++-15"
      C_COMPILER="gcc-15"
    elif command -v g++-14 >/dev/null 2>&1; then
      CXX_COMPILER="g++-14"
      C_COMPILER="gcc-14"
      echo "WARNING: falling back to g++-14 — full module matrix may fail on this platform." >&2
    else
      echo "ERROR: no suitable g++ found for GCC row." >&2
      return 1
    fi
  elif [[ "$compiler_field" == "Clang" ]]; then
    TEST_CLI_COMPILER="clang"
    local cand
    for cand in clang++-21 clang++-20 clang++-19 clang++-18 clang++; do
      if command -v "$cand" >/dev/null 2>&1; then
        CXX_COMPILER="$cand"
        C_COMPILER="${cand/clang++/clang}"
        break
      fi
    done
    if [[ -z "$CXX_COMPILER" ]]; then
      echo "ERROR: no clang++ found (tried clang++-21..18 and clang++)." >&2
      echo "On Mint: sudo apt install clang-20  (or clang-18)" >&2
      return 1
    fi
    local major_version
    major_version=$("$CXX_COMPILER" -dumpversion | cut -d. -f1)
    if (( major_version < 18 )); then
      echo "ERROR: $CXX_COMPILER version $major_version is too old (need 18+, 21+ preferred)." >&2
      return 1
    fi
    if (( major_version < 21 )); then
      echo "NOTE: $CXX_COMPILER is < 21 — build may work; RHEL parity uses Clang 21+." >&2
    fi
  else
    echo "ERROR: unknown compiler field '$compiler_field' (expected GCC or Clang)." >&2
    return 1
  fi

  if [[ -n "$CXX_COMPILER" ]] && ! command -v "$CXX_COMPILER" >/dev/null 2>&1 && [[ ! -x "$CXX_COMPILER" ]]; then
    echo "ERROR: compiler not found: $CXX_COMPILER" >&2
    return 1
  fi
}

process_checklist_row() {
  local checklist_line="$1"
  local row_num="$2"
  local row_total="$3"

  # Parse: [x] GCC    / RHEL 9.8 / ssd
  local details compiler_field platform_field disk_field
  details=$(echo "$checklist_line" | sed 's/^\[x\] *//')
  IFS='/' read -r compiler_field platform_field disk_field <<< "$details"
  compiler_field=$(echo "$compiler_field" | xargs)
  platform_field=$(echo "$platform_field" | xargs)
  disk_field=$(echo "$disk_field" | xargs)

  local disk_norm platform_slug compiler_slug build_dir
  disk_norm="$(normalize_disk "$disk_field")"
  platform_slug="$(slugify "$platform_field")"
  compiler_slug="$(slugify "$compiler_field")"
  build_dir="$PROJECT_ROOT/build-seq/${platform_slug}-${compiler_slug}"

  echo "=== ts_store Sequential Build ($row_num / $row_total) ==="
  echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Checklist: $CHECKLIST"
  echo "Running:   $checklist_line"
  echo "Parsed:    compiler=$compiler_field platform=$platform_field disk=$disk_norm"
  echo "Flags:     FullRebuild=$FULL_REBUILD SmokeTest=$SMOKE_TEST FullTest=$FULL_TEST"
  echo "Build dir: $build_dir (transient — removed after success)"
  echo

  resolve_compiler "$compiler_field" "$platform_field"

  echo "Compiler:  $CXX_COMPILER (cli --compiler $TEST_CLI_COMPILER)"
  if ((${#CMAKE_WRAPPER[@]} > 0)); then
    echo "Wrapper:   ${CMAKE_WRAPPER[*]}"
  fi
  echo

  if [[ "$FULL_REBUILD" == "On" ]]; then
    echo "FullRebuild=On: removing $build_dir"
    rm -rf "$build_dir"
  fi

  mkdir -p "$build_dir"
  cd "$build_dir"

  echo "=== CMake configure ==="
  if ((${#CMAKE_WRAPPER[@]} > 0)); then
    "${CMAKE_WRAPPER[@]}" cmake "${CMAKE_NINJA_ARGS[@]}" \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_CXX_COMPILER="$CXX_COMPILER" \
      -DCMAKE_C_COMPILER="$C_COMPILER" \
      -DTS_STORE_ENABLE_JTEXT_PERSIST=ON \
      -DTS_STORE_ENABLE_SQLITE_PERSIST=ON \
      "${DEPS_CMAKE_ARGS[@]}" \
      "$PROJECT_ROOT"
  else
    cmake "${CMAKE_NINJA_ARGS[@]}" \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_CXX_COMPILER="$CXX_COMPILER" \
      -DCMAKE_C_COMPILER="$C_COMPILER" \
      -DTS_STORE_ENABLE_JTEXT_PERSIST=ON \
      -DTS_STORE_ENABLE_SQLITE_PERSIST=ON \
      "${DEPS_CMAKE_ARGS[@]}" \
      "$PROJECT_ROOT"
  fi

  echo
  echo "=== Ninja build (${#MATRIX_TARGETS[@]} targets) ==="
  if ((${#CMAKE_WRAPPER[@]} > 0)); then
    "${CMAKE_WRAPPER[@]}" cmake --build . --target "${MATRIX_TARGETS[@]}" -j "$(nproc)"
  else
    cmake --build . --target "${MATRIX_TARGETS[@]}" -j "$(nproc)"
  fi

  local run_tests=0 test_size=""
  if [[ "$FULL_TEST" == "On" ]]; then
    run_tests=1
    test_size="full"
  elif [[ "$SMOKE_TEST" == "On" ]]; then
    run_tests=1
    test_size="smoke"
  fi

  if [[ "$run_tests" -eq 1 ]]; then
    local params_rel params_abs
    params_rel="build-seq/${platform_slug}-${compiler_slug}/run_params.txt"
    params_abs="$build_dir/run_params.txt"
    cp "$PROJECT_ROOT/tests/test_params.txt" "$params_abs"
    sed -i "s/^SIZE=.*/SIZE=${test_size}/" "$params_abs"
    sed -i "s/^DISK_TYPE=.*/DISK_TYPE=${disk_norm}/" "$params_abs"

    echo
    echo "=== Test matrix (SIZE=$test_size DISK=$disk_norm) ==="
    ./ts_test_cli run --compiler "$TEST_CLI_COMPILER" --disk "$disk_norm" --params "$params_rel"
  else
    echo
    echo "Skipping test matrix (SmokeTest=Off and FullTest=Off)."
  fi

  echo
  echo "=== Promote summaries ==="
  "$SCRIPT_DIR/promote_summaries.sh" --disk "$disk_norm"

  echo "=== Remove transient build tree ==="
  rm -rf "$build_dir"

  echo
  echo "=== Build complete for: $checklist_line ==="
  echo
}

echo "=== ts_store Sequential Build ==="
echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S')"
echo "Checklist: $CHECKLIST"
echo "[x] rows to run: $RUN_COUNT"
echo "Flags: FullRebuild=$FULL_REBUILD SmokeTest=$SMOKE_TEST FullTest=$FULL_TEST"
echo

# shellcheck source=build_common.sh
source "$SCRIPT_DIR/build_common.sh"
ts_store_resolve_ninja
CMAKE_NINJA_ARGS=(-G Ninja -DCMAKE_MAKE_PROGRAM="$NINJA")

# Deps: siblings when present, otherwise vendor/
DEPS_CMAKE_ARGS=(-DTS_STORE_JTEXT_MODE=vendored -DTS_STORE_JACQLITE_MODE=vendored)
if [[ -d "$PROJECT_ROOT/../jText" && -d "$PROJECT_ROOT/../jacQlite" ]]; then
  DEPS_CMAKE_ARGS=(-DTS_STORE_JTEXT_MODE=reference -DTS_STORE_JACQLITE_MODE=reference)
  echo "Deps: reference (../jText + ../jacQlite)"
else
  echo "Deps: vendored"
fi
echo

MATRIX_TARGETS=(
  ts_test_cli
  ts_store_001_TS ts_store_001_XS
  ts_store_002_TS ts_store_002_XS
  ts_store_003_TS ts_store_003_XS
  ts_store_004_TS ts_store_004_XS
  ts_store_005_TS ts_store_005_XS
  ts_store_006_TS ts_store_006_XS
  ts_store_007_TS ts_store_007_XS
  ts_store_flags
  ts_store_jtext_high_throughput_test
  ts_store_jtext_split_demo
)

ROW_NUM=0
while IFS= read -r line || [[ -n "$line" ]]; do
  if [[ ! "$line" =~ ^\[x\] ]]; then
    continue
  fi
  ROW_NUM=$((ROW_NUM + 1))
  process_checklist_row "$line" "$ROW_NUM" "$RUN_COUNT"
done < "$CHECKLIST"

echo "=== All $ROW_NUM [x] row(s) complete ==="