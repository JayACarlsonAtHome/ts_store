#!/usr/bin/env bash
# Thin wrapper for ts_test_cli — finds a recent build-seq tree from ./scripts/Build.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

for candidate in \
    "${PROJECT_ROOT}"/build-seq/*/ts_test_cli \
    "${PWD}/ts_test_cli" \
    "$(command -v ts_test_cli 2>/dev/null || true)"
do
    if [[ -x "$candidate" ]]; then
        build_dir="$(cd "$(dirname "$candidate")" && pwd)"
        cd "$build_dir"
        exec ./ts_test_cli "$@"
    fi
done

echo "ts_test_cli not found."
echo "Build and test (recommended):"
echo "  ./scripts/Build FileCheckList.txt --FullRebuild=On --SmokeTest=On --FullTest=Off"
echo "Or run from an existing build-seq dir:"
echo "  cd build-seq/<platform>-<compiler> && ./ts_test_cli run --disk ssd"
exit 1